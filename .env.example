SECRET_KEY=your-super-secret-key-change-in-production
DATABASE_URL=sqlite:///./koi.db
RESTAURANT_NAME=Koi
RESTAURANT_ADDRESS=Calle Ejemplo 123, Madrid
RESTAURANT_PHONE=+34 91 234 56 78
RESTAURANT_EMAIL=hola@koi.es

# URL pública base (usada por Stripe para las redirecciones de éxito/cancelación)
BASE_URL=http://localhost:8000

# ---- Stripe (pasarela de pago) ----
# Consíguelas en https://dashboard.stripe.com/apikeys (usa las claves de test: sk_test_... / pk_test_...)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Secreto del webhook (whsec_...). Obtenido con `stripe listen` o desde el dashboard.
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur

# Gastos de envío para pedidos a domicilio (en euros)
DELIVERY_FEE=3.50
